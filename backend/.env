# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#  GeoSafe — Environment Configuration
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Copy this file to .env and update values

APP_NAME=GeoSafe API
APP_VERSION=1.0.0
DEBUG=true
USE_DEMO_DATA=false
SECRET_KEY=change-me-in-production

# ── Database (PostgreSQL + PostGIS) ──────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/geosafe
DATABASE_URL_SYNC=postgresql://postgres:postgres@localhost:5432/geosafe

# ── KGIS ─────────────────────────────────────
KGIS_WFS_BASE_URL=https://kgis.ksrsac.in/kgis/ows
KGIS_WMS_BASE_URL=https://kgis.ksrsac.in/kgis/wms
KGIS_DATA_SOURCE_MODE=webapi
# Set these using valid KGIS Nearby Asset layer codes
KGIS_NEARBY_ASSET_CODE_WATER_BODIES=
KGIS_NEARBY_ASSET_CODE_FOREST=
KGIS_NEARBY_ASSET_CODE_ECO_SENSITIVE=
KGIS_NEARBY_ASSET_CODE_FLOOD=
KGIS_NEARBY_ASSET_CODE_GOVT_LAND=
KGIS_NEARBY_ASSET_CODE_REVENUE_LAND=
# KGIS_API_KEY=

# ── LLM Provider ─────────────────────────────
LLM_PROVIDER=gemini
LLM_MODEL=gemini-2.5-flash
GOOGLE_API_KEY=AIzaSyAVG1pLu2FiOO7ynZzDkUxLpVyFRmDOZuw
# OPENAI_API_KEY=your-openai-api-key-here

# ── CORS ─────────────────────────────────────
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:5173"]
# 🌍 Base WMS (same for most layers)
BHUVAN_FOREST_WMS_URL=https://bhuvan-vec2.nrsc.gov.in/bhuvan/wms
BHUVAN_FOREST_LAYER_NAME=forest:KFD_WLS
BHUVAN_ESZ_WMS_URL=https://bhuvan-vec2.nrsc.gov.in/bhuvan/wms
BHUVAN_ESZ_LAYER_NAME=forest:WGEEP_ESZs
BHUVAN_FLOOD_WMS_URL=https://bhuvan-ras2.nrsc.gov.in/cgi-bin/flood.exe
BHUVAN_FLOOD_LAYER_NAME=Flood
BHUVAN_GOVT_LAND_WMS_URL=
BHUVAN_GOVT_LAND_LAYER_NAME=
FALLBACK_POINTS_PATH=data/fallback_points.json
FALLBACK_POINT_RADIUS_M=2500
ENABLE_KARNATAKA_HEURISTIC_FALLBACK=true
