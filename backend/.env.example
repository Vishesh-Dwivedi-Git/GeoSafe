# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#  GeoSafe — Environment Configuration
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Copy this file to .env and update values

APP_NAME=GeoSafe API
APP_VERSION=1.0.0
DEBUG=true
SECRET_KEY=change-me-in-production
ENABLE_DATABASE=false

# ── Database (PostgreSQL + PostGIS) ──────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/geosafe
DATABASE_URL_SYNC=postgresql://postgres:postgres@localhost:5432/geosafe

# ── KGIS ─────────────────────────────────────
KGIS_WFS_BASE_URL=https://kgis.ksrsac.in/kgis/ows
KGIS_WMS_BASE_URL=https://kgis.ksrsac.in/kgis/wms
KGIS_DATA_SOURCE_MODE=mixed
OVERPASS_API_URL=https://overpass-api.de/api/interpreter
# KGIS_API_KEY=
KGIS_LAYER_WATER_BODIES_GEOJSON_PATH=
KGIS_LAYER_WATER_BODIES_GEOJSON_URL=
KGIS_LAYER_FOREST_GEOJSON_PATH=
KGIS_LAYER_FOREST_GEOJSON_URL=
KGIS_LAYER_ECO_SENSITIVE_GEOJSON_PATH=
KGIS_LAYER_ECO_SENSITIVE_GEOJSON_URL=
KGIS_LAYER_FLOOD_GEOJSON_PATH=
KGIS_LAYER_FLOOD_GEOJSON_URL=
KGIS_LAYER_GOVT_LAND_GEOJSON_PATH=
KGIS_LAYER_GOVT_LAND_GEOJSON_URL=
KGIS_LAYER_REVENUE_LAND_GEOJSON_PATH=
KGIS_LAYER_REVENUE_LAND_GEOJSON_URL=
KGIS_NEARBY_ASSET_CODE_WATER_BODIES=
KGIS_NEARBY_ASSET_CODE_FOREST=
KGIS_NEARBY_ASSET_CODE_ECO_SENSITIVE=
KGIS_NEARBY_ASSET_CODE_FLOOD=
KGIS_NEARBY_ASSET_CODE_GOVT_LAND=
KGIS_NEARBY_ASSET_CODE_REVENUE_LAND=
BHUVAN_FOREST_WMS_URL=
BHUVAN_FOREST_LAYER_NAME=
BHUVAN_ESZ_WMS_URL=
BHUVAN_ESZ_LAYER_NAME=
BHUVAN_FLOOD_WMS_URL=
BHUVAN_FLOOD_LAYER_NAME=
BHUVAN_GOVT_LAND_WMS_URL=
BHUVAN_GOVT_LAND_LAYER_NAME=
GIS_LAYER_CACHE_TTL_SECONDS=900
ANALYZE_BUFFER_M=500
FALLBACK_POINTS_PATH=data/fallback_points.json
FALLBACK_POINT_RADIUS_M=2500
ENABLE_KARNATAKA_HEURISTIC_FALLBACK=true

# ── LLM Provider ─────────────────────────────
LLM_PROVIDER=gemini
LLM_MODEL=gemini-1.5-flash
AI_MODEL_PATH=../ml/model.pkl
AI_LABEL_ENCODER_PATH=../ml/label_encoder.pkl
# GOOGLE_API_KEY=your-google-api-key-here
# OPENAI_API_KEY=your-openai-api-key-here

# ── CORS ─────────────────────────────────────
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:5173"]
